# ---------------------------------------------------------------------------
# Environment template — committed, NO real values.
# Copy to .env.local and fill in. .env.local is gitignored.
# ---------------------------------------------------------------------------

# Supabase TRANSACTION POOLER (PgBouncer), port 6543 — used by the app at
# RUNTIME. Pooled connection, prepared statements disabled. Read by the Drizzle
# client in src/db/index.ts.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?sslmode=require"

# Supabase DIRECT CONNECTION, port 5432 — used ONLY for migrations / drizzle-kit
# (schema diffing needs a non-pooled session connection). Read by drizzle.config.ts.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Auth.js v5 session/JWT signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Base URL of the app. http://localhost:3000 in dev; production hostname in prod.
NEXTAUTH_URL="http://localhost:3000"
